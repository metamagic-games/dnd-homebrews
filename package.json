{
  "name": "dnd-homebrews",
  "version": "1.1.1",
  "description": "D&D 5e homebrew content by @mcclowes",
  "private": true,
  "scripts": {
    "build": "babel-node scripts/createRulebooks",
    "watch": "watch 'npm run build' ./src --wait=1",
    "format": "prettier --write scripts/ src/",
    "format:check": "prettier --check scripts/ src/",
    "format:staged": "pretty-quick --staged --pattern \"{src,scripts,__tests__}/**/*.{js,md,json}\"",
    "spellcheck": "cspell --no-progress \"src/**/*.md\" \"README.md\"",
    "spellcheck:staged": "git diff --cached --name-only --diff-filter=ACM | grep -E '\\.(md)$' | xargs -I{} cspell --no-must-find-files --no-progress \"{}\"",
    "test": "jest",
    "test:watch": "jest --watch --runInBand --bail",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/metamagic-games/dnd-homebrews.git"
  },
  "keywords": [
    "dnd",
    "homebrew",
    "rules",
    "game"
  ],
  "author": "Max Clayton Clowes <maxcc@me.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/metamagic-games/dnd-homebrews/issues"
  },
  "homepage": "https://github.com/metamagic-games/dnd-homebrews#readme",
  "devDependencies": {
    "@babel/cli": "^7.12.1",
    "@babel/core": "^7.12.3",
    "@babel/node": "^7.12.1",
    "@babel/preset-env": "^7.12.1",
    "cspell": "^10.0.0",
    "handbooker": "^1.6.6",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "prettier": "^2.2.1",
    "pretty-quick": "^3.1.0",
    "watch": "^1.0.2"
  }
}
